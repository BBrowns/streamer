generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String?  @map("display_name")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  refreshTokens       RefreshToken[]
  addons              InstalledAddon[]
  passwordResetTokens PasswordResetToken[]
  libraryItems        LibraryItem[]
  watchProgress       WatchProgress[]
  traktToken          TraktToken?

  @@map("users")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model InstalledAddon {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  transportUrl String   @map("transport_url")
  manifest     String
  installedAt  DateTime @default(now()) @map("installed_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, transportUrl])
  @@map("installed_addons")
}

// -- NEW MODELS: Library & Watch Progress --

model LibraryItem {
  id      String   @id @default(uuid())
  userId  String   @map("user_id")
  type    String   // "movie" | "series"
  itemId  String   @map("item_id") // IMDB/TMDB ID
  title   String
  poster  String?
  addedAt DateTime @default(now()) @map("added_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
  @@index([userId, addedAt])
  @@map("library_items")
}

model WatchProgress {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  type        String
  itemId      String   @map("item_id")
  season      Int      @default(0)
  episode     Int      @default(0)
  currentTime Float    @map("current_time")
  duration    Float
  title       String
  poster      String?
  lastWatched DateTime @default(now()) @map("last_watched")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId, season, episode])
  @@index([userId, lastWatched])
  @@map("watch_progress")
}

// -- NEW MODEL: Trakt.tv Token Storage --

model TraktToken {
  id           String   @id @default(uuid())
  userId       String   @unique @map("user_id")
  accessToken  String   @map("access_token")
  refreshToken String   @map("refresh_token")
  expiresAt    DateTime @map("expires_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("trakt_tokens")
}
