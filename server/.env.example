# Server environment variables
# Copy to .env and fill in values

# Database — PostgreSQL (local dev or cloud provider)
DATABASE_URL="postgresql://streamer:streamer_dev@127.0.0.1:5432/streamer_db?schema=public"

# JWT
JWT_SECRET=change-me-in-production-use-a-strong-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug
SERVER_INSTANCE_MODE=single
TRUST_PROXY_HOPS=0
SHUTDOWN_TIMEOUT_MS=10000
RATE_LIMIT_GLOBAL_MAX=1000

# Build metadata (usually injected by CI/release jobs)
STREAMER_APP_VERSION=0.1.0
STREAMER_GIT_SHA=unknown
STREAMER_BUILD_DATE=unknown
STREAMER_BUILD_CHANNEL=development
STREAMER_BUILD_ENVIRONMENT=development

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Redis (rate limiting and cross-instance/session state)
# Required when SERVER_INSTANCE_MODE=multi. Optional in single-instance mode.
# REDIS_URL=redis://localhost:6379

# Email. Development may log redacted messages; production requires smtp.
EMAIL_DELIVERY_MODE=log
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=streamer
# SMTP_PASS=replace-with-a-secret
SMTP_FROM=noreply@streamer.app

# Public links used in verification and password-recovery email
APP_URL_WEB=http://localhost:8081
APP_URL_DEEPLINK=streamer://
