    "axios": "^1.7.9",
    "bcryptjs": "^3.0.2",
    "cockatiel": "^3.2.1",
    "express-rate-limit": "^8.2.1",
    "hono": "^4.12.5",
    "jsonwebtoken": "^9.0.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.0.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.12.0",
    "@types/bcryptjs": "^2.4.6",
