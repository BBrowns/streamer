{
    "name": "@streamer/server",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc",
        "start": "node dist/index.js",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src/",
        "db:generate": "prisma generate",
        "db:push": "prisma db push",
        "db:seed": "tsx src/prisma/seed.ts",
        "db:studio": "prisma studio"
    },
    "dependencies": {
        "@streamer/shared": "*",
        "express": "^5.1.0",
        "cors": "^2.8.5",
        "helmet": "^8.0.0",
        "jsonwebtoken": "^9.0.0",
        "bcryptjs": "^3.0.2",
        "pino": "^9.6.0",
        "pino-pretty": "^13.0.0",
        "pino-http": "^10.4.0",
        "cockatiel": "^3.2.1",
        "zod": "^3.24.0",
        "axios": "^1.7.9",
        "uuid": "^11.1.0",
        "@prisma/client": "^6.4.0",
        "express-rate-limit": "^7.5.0"
    },
    "devDependencies": {
        "@types/express": "^5.0.0",
        "@types/cors": "^2.8.17",
        "@types/jsonwebtoken": "^9.0.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/uuid": "^10.0.0",
        "prisma": "^6.4.0",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0",
        "vitest": "^3.0.0",
        "supertest": "^7.0.0",
        "@types/supertest": "^6.0.0"
    }
}