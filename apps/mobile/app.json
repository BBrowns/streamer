{
  "expo": {
    "name": "Streamer",
    "slug": "streamer",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "streamer",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fbf6f4"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bbrowns.streamer",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.bbrowns.streamer",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#fbf6f4"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "react-native-google-cast",
      "expo-video",
      "expo-font",
      "expo-secure-store",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
