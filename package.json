{
  "name": "streamer",
  "version": "0.1.0",
  "private": true,
  "description": "Cross-platform media streaming aggregator",
  "workspaces": [
    "packages/*",
    "server",
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev:server & npm run dev:stream-server & sleep 2 && npm run dev:mobile",
    "dev:server": "kill -9 $(lsof -ti :3001) 2>/dev/null; npm run dev --workspace=server",
    "dev:mobile": "npm run start --workspace=apps/mobile",
    "dev:desktop": "npm run dev --workspace=@streamer/desktop",
    "dev:stream-server": "kill -9 $(lsof -ti :11470) 2>/dev/null; npm run dev --workspace=@streamer/stream-server",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test:all": "turbo run test",
    "typecheck:all": "turbo run typecheck",
    "postinstall": "patch-package",
    "prepare": "husky"
  },
  "devDependencies": {
    "electron": "^40.6.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "patch-package": "^8.0.1",
    "prettier": "^3.4.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "overrides": {
    "ip": "^2.0.1",
    "zod": "^3.25.76",
    "bittorrent-tracker": {
      "ip": "^2.0.1"
    },
    "ip-set": {
      "ip": "^2.0.1"
    },
    "load-ip-set": {
      "ip-set": {
        "ip": "^2.0.1"
      }
    },
    "torrent-discovery": {
      "bittorrent-tracker": {
        "ip": "^2.0.1"
      }
    },
    "rimraf": "^6.0.1",
    "glob": "^11.0.1"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx,json,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "npm@10.9.0",
  "dependencies": {
    "expo": "~55.0.5",
    "expo-video": "~55.0.10"
  }
}
